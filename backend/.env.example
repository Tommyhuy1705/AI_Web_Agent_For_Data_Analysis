# ============================================================
# Omni-Revenue Agent - Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Supabase Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Required for SQL Proxy direct PostgreSQL access and dbt transforms
SUPABASE_DATABASE_URL=postgresql://readonly_ai:your_password@db.your_project.supabase.co:5432/postgres
SUPABASE_DB_HOST=db.your_project.supabase.co
SUPABASE_DB_USER=readonly_ai
SUPABASE_DB_PASSWORD=your_password
SUPABASE_DB_NAME=postgres

# Dify AI Platform
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=app-your_dify_api_key
DIFY_WEBHOOK_URL=https://api.dify.ai/v1/workflows/run

# OpenAI (fallback if DashScope not configured)
OPENAI_API_KEY=sk-your_openai_api_key

# DashScope / Qwen (Primary LLM Provider - FREE quota)
# Priority: DASHSCOPE_API_KEY > OPENAI_API_KEY
# Get free key at: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your_dashscope_api_key
DASHSCOPE_MODEL=qwen3.5-122b-a10b

# Zilliz Vector DB
ZILLIZ_CLOUD_URI=https://your-instance.zillizcloud.com
ZILLIZ_API_KEY=your_zilliz_api_key

# SendGrid Email
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@omni-revenue.com
ALERT_RECIPIENTS=admin@company.com,manager@company.com

# Frontend
FRONTEND_URL=http://localhost:3000
